# -------------------------------------------------------------------
# YouTogether backend — environment variables
#
# Place it to the project root folder at the same level than package.json.
#
#   backend/
#   ├-- .env.example   ← this versioned file
#   ├-- .env           ← local copy not versioned
#   ├-- package.json
#   └-- src/
#
# How to use :
#   cp .env.example .env
#   # fill the values to your local configuration in .env
#
# the .env file is automatically loaded by ConfigModule.forRoot()
# in the package @nestjs/config / dotenv.
# Never commit .env in version control (add it to the .gitignore).
# -------------------------------------------------------------------

# -- PostgreSQL ------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=youtogether

# -- JWT -------------------------------------------------------------
# Secrets distincts for access and refresh tokens (OWASP A07).
# Minimal length recommended : 32 random characters.
# Generate with : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

JWT_ACCESS_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace_with_different_strong_random_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# -- Application -----------------------------------------------------
PORT=3000
NODE_ENV=development

# Allowed origins for CORS request.
# In prod, replace * by the exact URL of the Flutter Web client.
CORS_ORIGIN=*