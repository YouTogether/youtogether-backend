# =============================================================================
# YouTogether Backend — Test Environment Configuration
# =============================================================================
# This file is committed to the repository and contains safe defaults for
# local development. Sensitive overrides (passwords, secrets) should be
# placed in `.env.test.local` which is gitignored.
#
# These variables are loaded by test/setup-env.ts before Jest runs.
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_TEST_DATABASE=youtogether_test

# --- JWT (used by TokenService tests in B-A01-T3) ----------------------------
JWT_ACCESS_SECRET=test-access-secret-do-not-use-in-production
JWT_REFRESH_SECRET=test-refresh-secret-do-not-use-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
